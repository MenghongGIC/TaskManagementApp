<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.WorkspaceController"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;">

    <Label text="Create Workspace" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <Label text="Workspace Name"/>
    <TextField fx:id="workspaceNameField" promptText="Workspace Name"/>

    <Label text="Description"/>
    <TextArea fx:id="workspaceDescriptionField" prefRowCount="3" promptText="Description"/>

    <Label text="Owner"/>
    <ComboBox fx:id="ownerCombo" prefWidth="300"/>

    <Label text="Add Members"/>
    <ListView fx:id="membersSelector" prefHeight="170"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Create Workspace" onAction="#createWorkspace"/>
    </HBox>
</VBox>
