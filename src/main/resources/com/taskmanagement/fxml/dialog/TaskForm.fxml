<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.TaskFormController"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 16;">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label fx:id="formTitleLabel" text="Create Task" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <Label text="Title"/>
    <TextField fx:id="titleField" promptText="Task title"/>

    <Label text="Description"/>
    <TextArea fx:id="descriptionField" prefRowCount="3" wrapText="true"/>

    <HBox spacing="10">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Status"/>
            <ComboBox fx:id="statusCombo"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Priority"/>
            <ComboBox fx:id="priorityCombo"/>
        </VBox>
    </HBox>

    <Label text="Due Date"/>
    <DatePicker fx:id="dueDatePicker"/>

    <Label text="Assignee"/>
    <ComboBox fx:id="assigneeCombo"/>

    <Label fx:id="messageLabel" text="" visible="false" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save" onAction="#handleSave"/>
    </HBox>
</VBox>
