<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 16;">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="Project Form" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <Label text="Name"/>
    <TextField promptText="Project name"/>
    <Label text="Description"/>
    <TextArea prefRowCount="3" wrapText="true"/>
    <Label text="Color"/>
    <TextField promptText="#3498db"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Cancel"/>
        <Button text="Save"/>
    </HBox>
</VBox>
