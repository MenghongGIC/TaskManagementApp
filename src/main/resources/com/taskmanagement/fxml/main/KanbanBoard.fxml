<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.KanbanController"
      spacing="16"
      style="-fx-background-color: #F8FAFC; -fx-padding: 20;">

    <!-- Page Title -->
    <Label text="Kanban Board"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" />

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0; -fx-background-color: #F8FAFC;">
        <Region HBox.hgrow="ALWAYS"/>
        <Button styleClass="btn-primary" style="-fx-padding: 8 16; -fx-content-display: LEFT;" onAction="#refreshBoard">
            <graphic>
                <FontIcon iconLiteral="fas-sync-alt" iconSize="14" style="-fx-icon-color: #FFFFFF;" />
            </graphic>
            <text>Refresh Board</text>
        </Button>
    </HBox>

    <!-- Scrollable Board Area -->
    <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-border-color: transparent;">
        <content>

            <!-- 3 Boards Container -->
            <HBox spacing="20"
                  style="-fx-padding: 12; -fx-alignment: TOP_LEFT; -fx-background-color: #F8FAFC;">

                <!-- TO DO BOARD -->
                <VBox spacing="12"
                      HBox.hgrow="ALWAYS"
                      style="
                      -fx-background-color: #F3F4F6;
                      -fx-border-color: #E5E7EB;
                      -fx-border-width: 1;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      -fx-padding: 16;
                      -fx-min-width: 300;
                      -fx-pref-width: 340;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">

                    <!-- Header -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-tasks" iconSize="16" style="-fx-icon-color: #6B7280;" />
                        <Label text="To Do"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label fx:id="todoCountLabel"
                               text="0"
                               style="
                               -fx-background-color: rgba(0, 0, 0, 0.1);
                               -fx-text-fill: #373F4F;
                               -fx-padding: 2 8;
                               -fx-background-radius: 10;
                               -fx-font-weight: bold;
                               -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Task Container -->
                    <VBox fx:id="todoColumn"
                          spacing="12"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;"/>
                </VBox>


                <!-- IN PROGRESS BOARD -->
                <VBox spacing="12"
                      HBox.hgrow="ALWAYS"
                      style="
                      -fx-background-color: #FEF3C7;
                      -fx-border-color: #FCD34D;
                      -fx-border-width: 1;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      -fx-padding: 16;
                      -fx-min-width: 300;
                      -fx-pref-width: 340;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">

                    <!-- Header -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-cog" iconSize="16" style="-fx-icon-color: #8B5CF6;" />
                        <Label text="In Progress"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label fx:id="inProgressCountLabel"
                               text="0"
                               style="
                               -fx-background-color: rgba(0, 0, 0, 0.1);
                               -fx-text-fill: #78350F;
                               -fx-padding: 2 8;
                               -fx-background-radius: 10;
                               -fx-font-weight: bold;
                               -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Task Container -->
                    <VBox fx:id="inProgressColumn"
                          spacing="12"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;"/>
                </VBox>


                <!-- DONE BOARD -->
                <VBox spacing="12"
                      HBox.hgrow="ALWAYS"
                      style="
                      -fx-background-color: #DCFCE7;
                      -fx-border-color: #86EFAC;
                      -fx-border-width: 1;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      -fx-padding: 16;
                      -fx-min-width: 300;
                      -fx-pref-width: 340;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">

                    <!-- Header -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-check-circle" iconSize="16" style="-fx-icon-color: #22C55E;" />
                        <Label text="Done"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label fx:id="doneCountLabel"
                               text="0"
                               style="
                               -fx-background-color: rgba(0, 0, 0, 0.1);
                               -fx-text-fill: #166534;
                               -fx-padding: 2 8;
                               -fx-background-radius: 10;
                               -fx-font-weight: bold;
                               -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Task Container -->
                    <VBox fx:id="doneColumn"
                          spacing="12"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;"/>
                </VBox>

            </HBox>

        </content>
    </ScrollPane>

</VBox>