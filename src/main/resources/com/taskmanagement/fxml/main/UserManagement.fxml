<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.UserManagementController"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;">

    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by username or email..." prefWidth="300"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh" style="-fx-padding: 8px 16px;"/>
    </HBox>

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="usernameColumn" text="Username" prefWidth="140"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="220"/>
            <TableColumn fx:id="roleColumn" text="Role" prefWidth="100"/>
            <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="180"/>
            <TableColumn fx:id="actionColumn" text="Actions" prefWidth="120"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel" text="Loading users..." style="-fx-padding: 8px;"/>
</VBox>
