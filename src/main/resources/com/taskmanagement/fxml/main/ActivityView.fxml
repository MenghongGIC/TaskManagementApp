<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.ActivityController"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;">

    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label text="Activity" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#refresh"/>
        <Button text="Clear" onAction="#clearAll"/>
    </HBox>

    <TableView fx:id="activityTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timeColumn" text="Time" prefWidth="150"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="150"/>
            <TableColumn fx:id="entityColumn" text="Entity" prefWidth="110"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
            <TableColumn fx:id="actorColumn" text="Actor" prefWidth="130"/>
            <TableColumn fx:id="detailsColumn" text="Details" prefWidth="320"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel" text="Ready"/>
</VBox>
