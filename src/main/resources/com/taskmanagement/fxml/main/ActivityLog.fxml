<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.taskmanagement.controller.ActivityLogController"
      style="-fx-background-color: #F8FAFC; -fx-padding: 20;"
      spacing="16" VBox.vgrow="ALWAYS">
    
    <!-- Page Title -->
    <Label text="Activity Log" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
    
    <!-- Header -->
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0;">
        <Region HBox.hgrow="ALWAYS"/>
        <Button styleClass="btn-primary" style="-fx-padding: 8 16; -fx-content-display: LEFT;" onAction="#refreshActivities">
            <graphic>
                <FontIcon iconLiteral="fas-sync-alt" iconSize="14" style="-fx-icon-color: #FFFFFF;" />
            </graphic>
            <text>Refresh</text>
        </Button>
        <Button styleClass="btn-danger" style="-fx-padding: 8 16; -fx-content-display: LEFT;" onAction="#clearAllActivities">
            <graphic>
                <FontIcon iconLiteral="fas-trash" iconSize="14" style="-fx-icon-color: #FFFFFF;" />
            </graphic>
            <text>Clear All</text>
        </Button>
    </HBox>
    
    <!-- Table -->
    <TableView fx:id="activityTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 12px;">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60" sortable="false"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="120" sortable="false"/>
            <TableColumn fx:id="entityTypeColumn" text="Type" prefWidth="100" sortable="false"/>
            <TableColumn fx:id="entityNameColumn" text="Entity Name" prefWidth="140" sortable="false"/>
            <TableColumn fx:id="userColumn" text="User" prefWidth="100" sortable="false"/>
            <TableColumn fx:id="detailsColumn" text="Details" prefWidth="180" sortable="false"/>
            <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="160" sortable="false"/>
        </columns>
    </TableView>
</VBox>
