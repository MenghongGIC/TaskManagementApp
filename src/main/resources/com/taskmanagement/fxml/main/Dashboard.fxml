<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.DashboardController"
      spacing="16"
      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;">

    <Label text="Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="12" vgap="12">
        <padding>
            <Insets top="8" right="0" bottom="8" left="0"/>
        </padding>

        <!-- Total Users -->
        <Button GridPane.rowIndex="0" GridPane.columnIndex="0" onAction="#navigateToAllUsers" styleClass="dashboard-card-button">
            <graphic>
                <VBox spacing="4">
                    <Label text="👥 Total Users" styleClass="dashboard-card-label-title"/>
                    <Label fx:id="totalUsersLabel" text="0" styleClass="dashboard-card-label-value"/>
                </VBox>
            </graphic>
        </Button>

        <!-- Total Tasks -->
        <Button GridPane.rowIndex="0" GridPane.columnIndex="1" onAction="#navigateToAllTasks" styleClass="dashboard-card-button">
            <graphic>
                <VBox spacing="4">
                    <Label text="📋 Total Tasks" styleClass="dashboard-card-label-title"/>
                    <Label fx:id="totalTasksLabel" text="0" styleClass="dashboard-card-label-value"/>
                </VBox>
            </graphic>
        </Button>

        <!-- Completed Tasks -->
        <Button GridPane.rowIndex="0" GridPane.columnIndex="2" onAction="#navigateToCompletedTasks" styleClass="dashboard-card-button">
            <graphic>
                <VBox spacing="4">
                    <Label text="✅ Completed" styleClass="dashboard-card-label-title"/>
                    <Label fx:id="completedTasksLabel" text="0" styleClass="dashboard-card-label-value"/>
                </VBox>
            </graphic>
        </Button>

        <!-- Overdue Tasks -->
        <Button GridPane.rowIndex="1" GridPane.columnIndex="0" onAction="#navigateToOverdueTasks" styleClass="dashboard-card-button">
            <graphic>
                <VBox spacing="4">
                    <Label text="⏰ Overdue Tasks" styleClass="dashboard-card-label-title"/>
                    <Label fx:id="overdueTasksLabel" text="0" styleClass="dashboard-card-label-value"/>
                </VBox>
            </graphic>
        </Button>

        <!-- In Progress Tasks -->
        <Button GridPane.rowIndex="1" GridPane.columnIndex="1" onAction="#navigateToInProgressTasks" styleClass="dashboard-card-button">
            <graphic>
                <VBox spacing="4">
                    <Label text="⚙️ In Progress" styleClass="dashboard-card-label-title"/>
                    <Label fx:id="inProgressTasksLabel" text="0" styleClass="dashboard-card-label-value"/>
                </VBox>
            </graphic>
        </Button>

        <!-- Pending Tasks -->
        <Button GridPane.rowIndex="1" GridPane.columnIndex="2" onAction="#navigateToPendingTasks" styleClass="dashboard-card-button">
            <graphic>
                <VBox spacing="4">
                    <Label text="📌 Pending Tasks" styleClass="dashboard-card-label-title"/>
                    <Label fx:id="pendingTasksLabel" text="0" styleClass="dashboard-card-label-value"/>
                </VBox>
            </graphic>
        </Button>
    </GridPane>

    <Button text="Refresh" onAction="#refresh" maxWidth="120"/>
</VBox>
