<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.DashboardController"
      spacing="16"
      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;">

    <Label text="Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="12" vgap="12">
        <padding>
            <Insets top="8" right="0" bottom="8" left="0"/>
        </padding>

        <VBox spacing="4" style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-background-radius: 8;" GridPane.rowIndex="0" GridPane.columnIndex="0">
            <Label text="Total Projects"/>
            <Label fx:id="totalProjectsLabel" text="0" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="4" style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-background-radius: 8;" GridPane.rowIndex="0" GridPane.columnIndex="1">
            <Label text="Total Tasks"/>
            <Label fx:id="totalTasksLabel" text="0" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="4" style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-background-radius: 8;" GridPane.rowIndex="1" GridPane.columnIndex="0">
            <Label text="Completed Tasks"/>
            <Label fx:id="completedTasksLabel" text="0" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="4" style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-background-radius: 8;" GridPane.rowIndex="1" GridPane.columnIndex="1">
            <Label text="Overdue Tasks"/>
            <Label fx:id="overdueTasksLabel" text="0" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>

    <Button text="Refresh" onAction="#refresh" maxWidth="120"/>
</VBox>
