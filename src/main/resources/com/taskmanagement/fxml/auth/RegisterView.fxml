<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane alignment="CENTER" styleClass="login-container" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.taskmanagement.controller.AuthController">

    <VBox alignment="TOP_CENTER" prefHeight="620" prefWidth="400" spacing="20" style="-fx-background-color: transparent; -fx-background-color: #2A78C5;">

        <padding>
            <Insets bottom="40" left="40" right="40" top="30" />
        </padding>

        <Label styleClass="login-title" text="Create Account" />
        <Label styleClass="login-subtitle" text="Join us today" />

        <VBox spacing="12" styleClass="login-form-card">
            <VBox spacing="6">
                <Label styleClass="form-label" text="Email Address" />
                <TextField fx:id="registerEmailField" promptText="Enter your email" styleClass="form-input" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="form-label" text="Username" />
                <TextField fx:id="registerUsernameField" promptText="Choose a username" styleClass="form-input" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="form-label" text="Password" />
                <PasswordField fx:id="registerPasswordField" promptText="Minimum 8 characters" styleClass="form-password" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="form-label" text="Confirm Password" />
                <PasswordField fx:id="registerConfirmPasswordField" promptText="Re-enter your password" styleClass="form-password" />
            </VBox>

            <Label fx:id="registerErrorLabel" styleClass="error-label" visible="false" wrapText="true" />
            <Label fx:id="registerSuccessLabel" styleClass="success-label" visible="false" wrapText="true" />

            <HBox alignment="CENTER">
                <Button onAction="#handleRegister" prefHeight="42" prefWidth="300" style="-fx-background-color: #2A78C5;" styleClass="login-button" text="Register" />
            </HBox>

            <HBox alignment="CENTER" spacing="5">
                <Label styleClass="register-text" text="Already have an account?" />
                <Hyperlink onAction="#goToLogin" styleClass="register-hyperlink" text="Sign in" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>
