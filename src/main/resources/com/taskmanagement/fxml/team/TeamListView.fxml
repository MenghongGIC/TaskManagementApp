<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanagement.controller.TeamController"
      spacing="10"
      style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 10;">

    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label text="Teams" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Create Team" onAction="#handleCreateTeam"/>
        <Button text="View Team" onAction="#handleViewTeam"/>
        <Button text="Edit Team" onAction="#handleEditTeam"/>
        <Button text="Remove Team" onAction="#handleRemoveTeam"/>
        <Button text="Refresh" onAction="#refreshTeams"/>
    </HBox>

    <TableView fx:id="teamTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="teamNameColumn" text="Team Name" prefWidth="220"/>
            <TableColumn fx:id="teamLeadColumn" text="Team Lead" prefWidth="180"/>
            <TableColumn fx:id="memberCountColumn" text="Number of Members" prefWidth="180"/>
            <TableColumn fx:id="createdDateColumn" text="Created Date" prefWidth="180"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel" text="Ready"/>
</VBox>
